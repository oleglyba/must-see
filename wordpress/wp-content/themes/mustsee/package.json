{
  "name": "mustsee-theme",
  "version": "1.0.0",
  "private": true,
  "description": "Must See Travel WordPress theme — Tailwind build",
  "scripts": {
    "build:main": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --minify",
    "build:critical": "tailwindcss -c ./tailwind.critical.config.js -i ./assets/css/tailwind.src.css -o ./assets/css/critical.css --minify",
    "build": "npm run build:critical && npm run build:main",
    "watch": "tailwindcss -i ./assets/css/tailwind.src.css -o ./assets/css/tailwind.css --watch"
  },
  "devDependencies": {
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17"
  }
}
